{
  "scopeName": "source.rawlang",
  "patterns": [
    {
      "name": "keyword.control.rawlang",
      "match": "\\b(if|else|while|for|func|return|to)\\b"
    },
    {
      "name": "support.function.rawlang",
      "match": "\\b(out|in)\\b"
    },
    {
      "name": "constant.numeric.rawlang",
      "match": "\\b[0-9]+\\b"
    },
    {
      "name": "string.quoted.double.rawlang",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "variable.rawlang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}